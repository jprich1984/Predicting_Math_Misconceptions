 = {\n","    \"QuestionText\": \"Cyrus has \\\\( \\\\frac{2}{3} \\\\) of a whole pie in the fridge. Robert eats \\\\( \\\\frac{1}{3} \\\\) of this piece. What fraction of the whole cake has Robert eaten?\",\n","    \"StudentExplanation\": \"Do two thirds-one third to find the amount that has been eaten because it is reducing because Robert is eats some of it \",\n","    \"Category\": ['False_Misconception'],\n","    \"Misconception\": ['Subtraction'],\n","    \"MC_Answer\": \"\\( \\\\frac{2}{3}-\\\\frac{1}{3} \\)\"\n","}\n","    test_sample = {\n","    \"QuestionText\": \"Alex has \\\\( \\\\frac{4}{5} \\\\) of pizza. they gives \\\\( \\\\frac{2}{5} \\\\) of their piece to Lucinda. What fraction of the whole pizza was given. Simplify\",\n","    \"StudentExplanation\": \"Since something is being given, I subtract: 4/5 - 2/5\",\n","    \"Category\": ['False_Misconception'],\n","    \"Misconception\": ['Subtraction'],\n","    \"MC_Answer\": \"\\\\( \\\\frac{2}{5} \\\\)\"\n","}\n","    test_sample={\n","    \"QuestionText\": \"What is 1/2 times 4\",\n","    \"StudentExplanation\": \"I did 1/2 \\\\times 4 by multiplying the bottom 2 by 4, leaving the top fixed.\",\n","    \"Category\": [\"False_Misconception\"],\n","    \"Misconception\": [\"Firstterm\", \"Inversion\"],\n","    \"MC_Answer\": \"\\\\( \\\\frac{1}{8} \\\\)\"\n","}\n","\n","    results = run_inference(\n","        model, tokenizer, test_sample,\n","        label_encoder_category, label_encoder_misconception,\n","        device\n","    )"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"E2XFpcEp4BRr"},"outputs":[],"source":["import random\n","found=False\n","if analysis:\n","    for ind, row in agg_val.iterrows():\n","        h=row[\"Misconception\"]\n","        for i in h:\n","            if i=='Ignores_zeroes':\n","\n","                q_text=row['QuestionText']\n","                r_text=row['StudentExplanation']\n","                cat=row['Category'][0]\n","                ans=row['MC_Answer']\n","                misc=row['Misconception']\n","\n","                if random.random()<0.2:\n","                    print(f\"{cat}\\n{q_text}\\n{r_text}\\n{ans}\\n{misc}\")\n","                    found=True\n","        if found:\n","            break"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"74DuBJ-t4BRr"},"outputs":[],"source":["import torch\n","import torch.nn as nn\n","import numpy as np\n","import os\n","import pandas as pd\n","from collections import Counter, defaultdict\n","from transformers import AutoModel, AutoTokenizer\n","from torch.utils.data import DataLoader\n","from sklearn.metrics import f1_score\n","\n","def display_analysis_results(counts, title):\n","    \"\"\"\n","    Calculates and prints the class-wise performance metrics (Recall, Precision, F1-Score)\n","    from the raw True Positive (TP), False Negative (FN), and False Positive (FP) counts.\n","    \"\"\"\n","    print(f\"\\n{'='*70}\")\n","    print(f\"CLASS-WISE PERFORMANCE ANALYSIS: {title}\")\n","    print(f\"{'='*70}\")\n","    # Header format\n","    print(f\"{'Class':<30} {'Total':>6} | {'TP':>4} {'FN (Missed)':>10} {'FP (Wrong)':>10} | {'Recall':>6} {'Precision':>9} {'F1-Score':>8}\")\n","    print(\"-\" * 115)\n","\n","    sorted_classes = sorted(counts['Total'].keys())\n","\n","    for class_name in sorted_classes:\n","        total = counts['Total'].get(class_name, 0)\n","        tp = counts['TP'].get(class_name, 0)\n","        fn = counts['FN'].get(class_name, 0)\n","        fp = counts['FP'].get(class_name, 0)\n","\n","        # Calculate metrics\n","        recall = tp / total if total > 0 else 0.0\n","        precision = tp / (tp + fp) if (tp + fp) > 0 else 0.0\n","        f1 = (2 * precision * recall) / (precision + recall) if (precision + recall) > 0 else 0.0\n","\n","        # Highlighting low-performing classes for attention\n","        highlight_start = \"🔴 \" if f1 < 0.5 and total > 5 else \"\"\n","\n","        print(f\"{highlight_start}{class_name:<30} {total:>6} | {tp:>4} {fn:>10} {fp:>10} | {recall:>6.2f} {precision:>9.2f} {f1:>8.2f}\")\n","\n","\n","def analyze_predictions_with_storage(model, tokenizer, val_df, label_encoder_category,\n","                                     label_encoder_misconception, device, batch_size=32,\n","                                     save_dir='/kaggle/working'):\n","    \"\"\"\n","    Runs inference on validation set and stores all misclassification details.\n","\n","    Returns:\n","        - category_counts: Counter dict with TP/FN/FP/Total\n","        - misconception_counts: Counter dict with TP/FN/FP/Total\n","        - missed_examples: DataFrame with all misclassified examples\n","    \"\"\"\n","    model.eval()\n","\n","    # Configuration based on model __init__ defaults\n","    MAX_MATH_FEATURES = model.max_math_features\n","\n","    # Create the dataset and loader\n","    val_dataset = MultiTaskDatasetWithMathContext(\n","        val_df,\n","        tokenizer,\n","        label_encoder_category,\n","        label_encoder_misconception,\n","        augmenter,\n","        use_math_context=True,\n","        max_math_features=MAX_MATH_FEATURES\n","    )\n","    val_loader = DataLoader(val_dataset, batch_size=batch_size, shuffle=False)\n","\n","    # Initialize counters for all classes\n","    category_counts = {\n","        'TP': Counter(), 'FN': Counter(), 'FP': Counter(), 'Total': Counter()\n","    }\n","    misconception_counts = {\n","        'TP': Counter(), 'FN': Counter(), 'FP': Counter(), 'Total': Counter()\n","    }\n","\n","    cat_classes = label_encoder_category.classes_\n","    misc_classes = label_encoder_misconception.classes_\n","\n","    # Storage for missed examples\n","    missed_examples = []\n","\n","    print(f\"\\n{'='*30}\\nStarting Validation Analysis with Storage\\n{'='*30}\")\n","\n","    batch_idx = 0\n","    with torch.no_grad():\n","        for batch in val_loader:\n","            input_ids = batch['input_ids'].to(device)\n","            attention_mask = batch['attention_mask'].to(device)\n","            math_features = batch.get('math_features').to(device)\n","            category_labels = batch['category'].to(device)\n","            misconception_labels = batch['misconception'].to(device)\n","\n","            # Get text data from batch\n","            questions = batch['question_text']\n","            explanations = batch['explanation_text']\n","\n","            # Forward pass\n","            _, logits_category, logits_misconception = model(\n","                input_ids, attention_mask, math_features\n","            )\n","\n","            # Predictions\n","            preds_category = (torch.sigmoid(logits_category) > 0.5).cpu().numpy().astype(int)\n","            labels_category = category_labels.cpu().numpy().astype(int)\n","            preds_misconception = (torch.sigmoid(logits_misconception) > 0.5).cpu().numpy().astype(int)\n","            labels_misconception = misconception_labels.cpu().numpy().astype(int)\n","\n","            # Get probabilities for analysis\n","            probs_category = torch.sigmoid(logits_category).cpu().numpy()\n","            probs_misconception = torch.sigmoid(logits_misconception).cpu().numpy()\n","\n","            # --- Process each example in the batch ---\n","            batch_size_actual = len(questions)\n","            for i in range(batch_size_actual):\n","                example_idx = batch_idx * batch_size + i\n","\n","                # Get ground truth labels\n","                true_categories = [cat_classes[j] for j in range(len(cat_classes)) if labels_category[i, j] == 1]\n","                true_misconceptions = [misc_classes[j] for j in range(len(misc_classes)) if labels_misconception[i, j] == 1]\n","\n","                # Get predicted labels\n","                pred_categories = [cat_classes[j] for j in range(len(cat_classes)) if preds_category[i, j] == 1]\n","                pred_misconceptions = [misc_classes[j] for j in range(len(misc_classes)) if preds_misconception[i, j] == 1]\n","\n","                # Check if there are any misclassifications\n","                category_missed = set(true_categories) != set(pred_categories)\n","                misconception_missed = set(true_misconceptions) != set(pred_misconceptions)\n","\n","                if category_missed or misconception_missed:\n","                    # Get top 3 predictions for each\n","                    top3_cat_idx = np.argsort(probs_category[i])[-3:][::-1]\n","                    top3_cat = [(cat_classes[idx], probs_category[i, idx]) for idx in top3_cat_idx]\n","\n","                    top3_misc_idx = np.argsort(probs_misconception[i])[-3:][::-1]\n","                    top3_misc = [(misc_classes[idx], probs_misconception[i, idx]) for idx in top3_misc_idx]\n","\n","                    # Store missed example\n","                    missed_examples.append({\n","                        'Example_ID': example_idx,\n","                        'QuestionText': questions[i],\n","                        'StudentExplanation': explanations[i],\n","                        'True_Categories': ', '.join(true_categories),\n","                        'Predicted_Categories': ', '.join(pred_categories),\n","                        'Top3_Categories': ', '.join([f\"{name}({prob:.3f})\" for name, prob in top3_cat]),\n","                        'True_Misconceptions': ', '.join(true_misconceptions),\n","                        'Predicted_Misconceptions': ', '.join(pred_misconceptions),\n","                        'Top3_Misconceptions': ', '.join([f\"{name}({prob:.3f})\" for name, prob in top3_misc]),\n","                        'Category_Missed': category_missed,\n","                        'Misconception_Missed': misconception_missed\n","                    })\n","\n","            # --- Aggregate Counts for Category ---\n","            for i in range(len(cat_classes)):\n","                cat_name = cat_classes[i]\n","                labels_i = labels_category[:, i]\n","                preds_i = preds_category[:, i]\n","\n","                category_counts['Total'][cat_name] += np.sum(labels_i)\n","                category_counts['TP'][cat_name] += np.sum((labels_i == 1) & (preds_i == 1))\n","                category_counts['FN'][cat_name] += np.sum((labels_i == 1) & (preds_i == 0))\n","                category_counts['FP'][cat_name] += np.sum((labels_i == 0) & (preds_i == 1))\n","\n","            # --- Aggregate Counts for Misconception ---\n","            for i in range(len(misc_classes)):\n","                misc_name = misc_classes[i]\n","                labels_i = labels_misconception[:, i]\n","                preds_i = preds_misconception[:, i]\n","\n","                misconception_counts['Total'][misc_name] += np.sum(labels_i)\n","                misconception_counts['TP'][misc_name] += np.sum((labels_i == 1) & (preds_i == 1))\n","                misconception_counts['FN'][misc_name] += np.sum((labels_i == 1) & (preds_i == 0))\n","                misconception_counts['FP'][misc_name] += np.sum((labels_i == 0) & (preds_i == 1))\n","\n","            batch_idx += 1\n","\n","    # Convert missed examples to DataFrame\n","    missed_df = pd.DataFrame(missed_examples)\n","\n","    # Save to CSV\n","    os.makedirs(save_dir, exist_ok=True)\n","    missed_csv_path = os.path.join(save_dir, 'missed_predictions.csv')\n","    missed_df.to_csv(missed_csv_path, index=False)\n","    print(f\"\\n✅ Saved {len(missed_df)} missed predictions to: {missed_csv_path}\")\n","\n","    # Also save separate CSVs for category-only and misconception-only misses\n","    cat_missed_df = missed_df[missed_df['Category_Missed'] == True]\n","    misc_missed_df = missed_df[missed_df['Misconception_Missed'] == True]\n","\n","    cat_missed_path = os.path.join(save_dir, 'category_missed.csv')\n","    misc_missed_path = os.path.join(save_dir, 'misconception_missed.csv')\n","\n","    cat_missed_df.to_csv(cat_missed_path, index=False)\n","    misc_missed_df.to_csv(misc_missed_path, index=False)\n","\n","    print(f\"✅ Saved {len(cat_missed_df)} category misses to: {cat_missed_path}\")\n","    print(f\"✅ Saved {len(misc_missed_df)} misconception misses to: {misc_missed_path}\")\n","\n","    return category_counts, misconception_counts, missed_df\n","\n","if validation:\n","# =========================================================================\n","# === EXECUTION BLOCK ===\n","# =========================================================================\n","\n","    # --- User-Defined Path ---\n","    checkpoint_path = '/kaggle/input/model_after_balance/pytorch/default/1'\n","\n","    # 1. Setup Device and Tokenizer\n","    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","    tokenizer = AutoTokenizer.from_pretrained('microsoft/deberta-v3-base')\n","\n","    # 2. Instantiate Model\n","    num_categories = len(label_encoder_category.classes_)\n","    num_misc_classes = len(label_encoder_misconception.classes_)\n","\n","    model = MultiTaskDeBERTaWithMathContext(\n","        'microsoft/deberta-v3-base',\n","        num_categories=num_categories,\n","        num_misc_classes=num_misc_classes,\n","        max_math_features=200,\n","        math_feature_dim=128\n","    )\n","    model.to(device)\n","\n","    # 3. Load Weights\n","    print(f\"\\nLoading model from checkpoint path: {checkpoint_path}\")\n","    try:\n","        model_file = [f for f in os.listdir(checkpoint_path) if f.endswith('.pt') or f.endswith('.pth')][0]\n","        checkpoint_file = os.path.join(checkpoint_path, model_file)\n","\n","        checkpoint = torch.load(checkpoint_file, map_location=device, weights_only=False)\n","        model.load_state_dict(checkpoint['model_state_dict'], strict=False)\n","        print(\"✅ Model weights loaded successfully.\")\n","    except Exception as e:\n","        print(f\"❌ Error loading checkpoint weights: {e}\")\n","        print(\"Continuing analysis with current model state (might be random/untrained).\")\n","\n","    # 4. Run Analysis with Storage\n","    category_counts, misconception_counts, missed_df = analyze_predictions_with_storage(\n","        model,\n","        tokenizer,\n","        agg_val,\n","        label_encoder_category,\n","        label_encoder_misconception,\n","        device,\n","        save_dir='/kaggle/working'\n","    )\n","\n","    # 5. Display Results\n","    display_analysis_results(category_counts, \"Category Performance\")\n","    display_analysis_results(misconception_counts, \"Misconception Performance\")\n","\n","    # 6. Show sample of missed predictions\n","    print(f\"\\n{'='*70}\")\n","    print(\"SAMPLE OF MISSED PREDICTIONS (First 5)\")\n","    print(f\"{'='*70}\")\n","    if len(missed_df) > 0:\n","        print(missed_df[['QuestionText', 'True_Misconceptions', 'Predicted_Misconceptions']].head())\n","    else:\n","        print(\"No missed predictions! Perfect model! 🎉\")"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"CYEG0kI74BRs"},"outputs":[],"source":["import pandas as pd\n","import textwrap\n","\n","def view_missed_samples(missed_df, misconception=None, category=None, n_samples=5,\n","                       missed_type='both', show_predictions=True):\n","    \"\"\"\n","    Display detailed view of missed predictions without truncation.\n","\n","    Args:\n","        missed_df: DataFrame with missed predictions\n","        misconception: Filter by true misconception (e.g., 'Wrong_Fraction')\n","        category: Filter by true category (e.g., 'False_Misconception')\n","        n_samples: Number of samples to display\n","        missed_type: 'both', 'category_only', 'misconception_only'\n","        show_predictions: Whether to show model's predictions and probabilities\n","    \"\"\"\n","\n","    # Set pandas display options to show full content\n","    pd.set_option('display.max_colwidth', None)\n","    pd.set_option('display.width', None)\n","    pd.set_option('display.m