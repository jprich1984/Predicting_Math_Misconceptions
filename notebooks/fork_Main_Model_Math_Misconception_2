ttention_mask'].to(device)\n","\n","    # Forward pass\n","    with torch.no_grad():\n","        correctness_logits, category_logits, misconception_logits = model(\n","            input_ids, attention_mask, math_features\n","        )\n","\n","    # Get predictions\n","    correctness_pred = torch.argmax(correctness_logits, dim=-1).item()\n","    category_probs = torch.sigmoid(category_logits).cpu().numpy()[0]\n","    misconception_probs = torch.sigmoid(misconception_logits).cpu().numpy()[0]\n","\n","    # Get top predictions\n","    category_preds = (category_probs > 0.5).astype(int)\n","    misconception_preds = (misconception_probs > 0.5).astype(int)\n","\n","    # Get top 3 categories and misconceptions\n","    top_category_indices = np.argsort(category_probs)[-3:][::-1]\n","    top_misconception_indices = np.argsort(misconception_probs)[-3:][::-1]\n","\n","    # Print results\n","    print(\"=\"*80)\n","    print(\"INFERENCE RESULTS\")\n","    print(\"=\"*80)\n","    print(f\"\\nQuestion: {question}\")\n","    print(f\"\\nStudent Explanation: {explanation}\")\n","    print(f\"Student Answer: {mc_answer}\")\n","    print()\n","\n","    print(f\"Correctness Prediction: {'Correct' if correctness_pred == 1 else 'Incorrect'}\")\n","    print()\n","\n","    print(\"Top 3 Category Predictions:\")\n","    for idx in top_category_indices:\n","        category_name = label_encoder_category.inverse_transform([idx])[0]\n","        prob = category_probs[idx]\n","        predicted = \"✓\" if category_preds[idx] == 1 else \"✗\"\n","        print(f\"  {predicted} {category_name}: {prob:.4f}\")\n","    print()\n","\n","    print(\"Top 3 Misconception Predictions:\")\n","    for idx in top_misconception_indices:\n","        misconception_name = label_encoder_misconception.inverse_transform([idx])[0]\n","        prob = misconception_probs[idx]\n","        predicted = \"✓\" if misconception_preds[idx] == 1 else \"✗\"\n","        print(f\"  {predicted} {misconception_name}: {prob:.