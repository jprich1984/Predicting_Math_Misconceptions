] = prob_df.max(axis=1)\n","\n","    # 3. Find the column *name* that corresponds to the maximum probability (which is the logit name)\n","    max_prob_column_name = prob_df.idxmax(axis=1)\n","\n","    # 4. Extract the Misconception Name from the column name (e.g., 'prob_Tacking' -> 'Tacking')\n","    # This relies on the convention that the misconception name follows the 'prob_' prefix.\n","    df['Predicted_Misconception_Name'] = max_prob_column_name.str.replace('prob_', '', regex=False)\n","\n","    return df\n","if analysis:\n","    # Example Usage (assuming other_df_with_predictions is your DataFrame):\n","    # --------------------------------------------------------------------------\n","\n","    # Assuming 'label_encoder_misconception' and 'other_df_with_predictions' are defined:\n","    prob_columns = [f\"prob_{col}\" for col in label_encoder_misconception.classes_]\n","\n","    # # Apply the function\n","    other_df_with_predictions = get_max_misconception_probability(other_df_with_predictions, prob_columns)\n","\n","    # # Display the new columns\n","    # print(other_df_with_predictions[['Predicted_Misconception_Name', 'Max_Misconception_Prob']].head())\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"X4rsL3mN4BRg"},"outputs":[],"source":["import pandas as pd\n","\n","def sample_predictions_by_misconception(df: pd.DataFrame, misconception_name: str, max_samples: int = 5):\n","    \"\"\"\n","    Filters the DataFrame by the predicted misconception name and prints\n","    a specified number of random samples with key details.\n","\n","    Args:\n","        df: The DataFrame containing prediction results.\n","        misconception_name: The value in the 'Predicted_Misconception_Name' column to filter by.\n","        max_samples: The maximum number of random samples to print.\n","    \"\"\"\n","    df=df.sample(frac=1)\n","    # Define the column to filter on (as specified in the prompt)\n","    FILTER_COLUMN = 'Predicted_Misconception_Nam