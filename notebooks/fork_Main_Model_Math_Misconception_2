egative_labels': list(fns),\n","                'true_labels': list(true_labels),\n","                'pred_labels': list(pred_labels)\n","            })\n","\n","    return results\n","\n","def get_label_confusion_summary(df_val_preds, column='misconception'):\n","    \"\"\"\n","    Get per-label confusion statistics\n","    \"\"\"\n","    from collections import defaultdict, Counter\n","\n","    label_stats = defaultdict(lambda: {'tp': 0, 'fp': 0, 'fn': 0, 'tn': 0})\n","\n","    for _, row in df_val_preds.iterrows():\n","        true_labels = set(row[f'true_{column}'])\n","        pred_labels = set(row[f'pred_{column}'])\n","\n","        # Get all possible labels from your encoder\n","        all_labels = set(label_encoder_misconception.classes_)\n","\n","        for label in all_labels:\n","            if label in true_labels and label in pred_labels:\n","                label_stats[label]['tp'] += 1\n","            elif label not in true_labels and label in pred_labels:\n","                label_stats[label]['fp'] += 1\n","            elif label in true_labels and label not in pred_labels:\n","                label_stats[label]['fn'] += 1\n","            else:\n","                label_stats[label]['tn'] += 1\n","\n","    # Calculate metrics per label\n","    summary = {}\n","    for label, stats in label_stats.items():\n","        precision = stats['tp'] / (stats['tp'] + stats['fp']) if (stats['tp'] + stats['fp']) > 0 else 0\n","        recall = stats['tp'] / (stats['tp'] + stats['fn']) if (stats['tp'] + stats['fn']) > 0 else 0\n","        f1 = 2 * (precision * recall) / (precision + recall) if (precision + recall) > 0 else 0\n","\n","        summary[label] = {\n","            'precision': precision,\n","            'recall': recall,\n","            'f1': f1,\n","            'support': stats['tp'] + stats['fn'],  # actual positives\n","            'predicted_positives': stats['tp'] + stats['fp'],\n","            **stats\n","        }\n","\n","    return summary