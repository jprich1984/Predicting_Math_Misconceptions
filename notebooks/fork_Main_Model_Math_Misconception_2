py as np\n","import pandas as pd\n","import os\n","from transformers import AutoModel, AutoTokenizer\n","# Assuming the necessary classes like MultiTaskDeBERTaWithMathContext,\n","# MultiTaskDatasetWithMathContext, and other required variables (label_encoder_misconception,\n","# augmenter, other_df_agg, etc.) are available in your notebook environment.\n","\n","\n","# --- 1. Prediction Function (Outputs Raw Logits) ---\n","def predict_misconception_logits(\n","    df: pd.DataFrame,\n","    model: torch.nn.Module,\n","    tokenizer: AutoTokenizer,\n","    label_encoder_category,\n","    label_encoder_misconception,\n","    augmenter,\n","    max_math_features: int,\n","    device: torch.device,\n","    batch_size: int = 64\n",") -> np.ndarray:\n","    \"\"\"\n","    Generates raw logits for the Misconception task on a given DataFrame.\n","    \"\"\"\n","    # Prepare the Dataset and DataLoader\n","    dataset = MultiTaskDatasetWithMathContext(\n","        df,\n","        tokenizer,\n","        label_encoder_category,\n","        label_encoder_misconception,\n","        augmenter,\n","        max_math_features=max_math_features,\n","        use_math_context=True,\n","        use_answer=True\n","    )\n","\n","    loader = torch.utils.data.DataLoader(dataset, batch_size=batch_size, shuffle=False)\n","\n","    # Prediction Loop\n","    model.eval()\n","    all_misconception_logits = []\n","\n","    with torch.no_grad():\n","        for batch in loader:\n","            input_ids = batch['input_ids'].to(device)\n","            attention_mask = batch['attention_mask'].to(device)\n","\n","            # Get math features and move to device\n","            math_features = batch.get('math_features')\n","            if math_features is not None:\n","                math_features = math_features.to(device)\n","\n","            # Forward pass - we only care about the third output (misconception_logits)\n","            _, _, logits_misconception = model(\n","                input_ids, attention_mask, math_features\n","            )\n","\n","            # Collect logits\n","            all_misconception_logits.append(logits_misconception.cpu().numpy())\n","\n","    # Concatenate and return\n","    return np.concatenate(all_misconception_logits, axis=0)\n","\n","# ------------------------------------------------------------------\n","# --- 2. Execution Block (Runs Prediction and Saves Probabilities) ---\n","# ------------------------------------------------------------------\n","analysis=False\n","if analysis:\n","    try:\n","        # Configuration setup (use base model name)\n","        PRETRAINED_MODEL_NAME = 'microsoft/deberta-v3-base' # Corrected base model name\n","        MAX_MATH_FEATURES = 200\n","        MATH_FEATURE_DIM = 128\n","\n","        # Determine the number of classes from the global label encoders\n","        num_categories = len(label_encoder_category.classes_)\n","        num_misc_classes = len(label_encoder_misconception.classes_)\n","\n","        # --- Model and Checkpoint Setup ---\n","        model = MultiTaskDeBERTaWithMathContext(\n","            PRETRAINED_MODEL_NAME,\n","            num_categories,\n","            num_misc_classes,\n","            max_math_features=MAX_MATH_FEATURES,\n","            math_feature_dim=MATH_FEATURE_DIM\n","        )\n","        tokenizer = AutoTokenizer.from_pretrained(PRETRAINED_MODEL_NAME)\n","        device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","\n","        # Load the checkpoint\n","        checkpoint_path = '/kaggle/input/final_model_submit/pytorch/default/1'\n","        files = os.listdir(checkpoint_path)\n","        model_files = [f for f in files if f.endswith(('.pt', '.pth', '.bin'))]\n","        model_file = os.path.join(checkpoint_path, model_files[0]) if model_files else checkpoint_path\n","\n","        checkpoint = torch.load(model_file, map_location=device, weights_only=False)\n","        if isinstance(checkpoint, dict) and 'model_state_dict