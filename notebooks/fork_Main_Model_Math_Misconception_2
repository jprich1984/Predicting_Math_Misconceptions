x:\n","             print(f\"Prob. ({misconception_name}): {row[prob_col_name]:.4f}\")\n","\n","        # Print remaining key fields\n","        print(f\"Question:      {row['QuestionText']}\")\n","        print(f\"Response:      {row['StudentExplanation']}\")\n","        print(f\"Answer:        {row['MC_Answer']}\")\n","        print(f\"True Category: {row['Category']}\")\n","        print(f\"Correctness:   {row['Correctness']}\")\n","\n","    print(\"\\n=============================================================\")\n","\n","if analysis:\n","    # --- EXAMPLE USAGE (requires your DataFrame to be present) ---\n","    # # Assuming 'other_df_with_predictions' is the DataFrame after running the previous steps:\n","\n","    # # 1. Define your probability columns list (used to confirm the existence of the specific prob column)\n","    # prob_columns_list = [f\"prob_{col}\" for col in label_encoder_misconception.classes_]\n","\n","    # # 2. Run the function for a specific misconception, e.g., 'Longer_is_bigger'\n","    # sample_predictions_by_misconception(other_df_with_predictions, 'Longer_is_bigger')\n","\n","    # # 3. Run the function for another one\n","    sample_predictions_by_misconception(other_df_with_predictions, 'No Misconception', max_samples=3)\n","\n","    # # 4. Run the function for a misconception that might not be in the data\n","    # sample_predictions_by_misconception(other_df_with_predictions, 'NonExistentMisconception')"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"v0frkJ6PWTx7"},"outputs":[],"source":["show_sample(other_df,'Other')"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"2uB0gyqC4BRg"},"outputs":[],"source":["import torch\n","import torch.nn as nn\n","import numpy as np\n","import os\n","from collections import Counter\n","from transformers import AutoModel, AutoTokenizer\n","from torch.utils.data import DataLoader\n","from sklearn.metrics import f1_score\n","import numpy as np\n","from collections import Counter # Already imported in your previous block\n","\n","def display_analysis_results(counts, title):\n","    \"\"\"\n","    Calculates and prints the class-wise performance metrics (Recall, Precision, F1-Score)\n","    from the raw True Positive (TP), False Negative (FN), and False Positive (FP) counts.\n","    \"\"\"\n","    print(f\"\\n{'='*70}\")\n","    print(f\"CLASS-WISE PERFORMANCE ANALYSIS: {title}\")\n","    print(f\"{'='*70}\")\n","    # Header format\n","    print(f\"{'Class':<30} {'Total':>6} | {'TP':>4} {'FN (Missed)':>10} {'FP (Wrong)':>10} | {'Recall':>6} {'Precision':>9} {'F1-Score':>8}\")\n","    print(\"-\" * 115)\n","\n","    sorted_classes = sorted(counts['Total'].keys())\n","\n","    for class_name in sorted_classes:\n","        total = counts['Total'].get(class_name, 0)\n","        tp = counts['TP'].get(class_name, 0)\n","        fn = counts['FN'].get(class_name, 0)\n","        fp = counts['FP'].get(class_name, 0)\n","\n","        # Calculate metrics\n","        recall = tp / total if total > 0 else 0.0\n","        precision = tp / (tp + fp) if (tp + fp) > 0 else 0.0\n","        f1 = (2 * precision * recall) / (precision + recall) if (precision + recall) > 0 else 0.0\n","\n","        # Highlighting low-performing classes for attention\n","        highlight_start = \"🔴 \" if f1 < 0.5 and total > 5 else \"\"\n","\n","        print(f\"{highlight_start}{class_name:<30} {total:>6} | {tp:>4} {fn:>10} {fp:>10} | {recall:>6.2f} {precision:>9.2f} {f1:>8.2f}\")\n","\n","# --- ASSUMPTION: All classes (Model, Dataset, Helpers) and data (agg_val, encoders) are defined ---\n","\n","def analyze_predictions(model, tokenizer, val_df, label_encoder_category, label_encoder_misconception, device, batch_size=32):\n","    \"\"\"\n","    Runs inference on the validation set (agg_val) and collects misclassification counts\n","    for categories and misconceptions.\n","    \"\"\"\n","    model.eval()\n","\n","    # Configuration based on model __init__ defaults\n"