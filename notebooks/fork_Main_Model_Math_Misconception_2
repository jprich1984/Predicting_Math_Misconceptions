mbers (addition, subtraction, multiplication, division)\n","    - Fraction operations with whole numbers (both simplified and unsimplified)\n","    - Fraction-to-fraction operations (multiplication and division, both forms)\n","    - Decimal equivalents of fractions\n","    - Comparisons between all numbers\n","    - Fraction numerator vs denominator comparisons\n","    - Floating point decimal part extraction and comparison\n","    \"\"\"\n","\n","    # Extract student answer\n","    sa_match = re.search(r'-?\\d+(?:\\.\\d+)?', mc_answer.replace('\\\\(','').replace('\\\\)','').replace(',',''))\n","    student_answer = sa_match.group(0) if sa_match else 'N/A'\n","\n","    # ===== STEP 1: Extract all numbers (integers and decimals) =====\n","    # Match negative and positive numbers, including decimals\n","    numbers_raw = re.findall(r'-?\\d+\\.\\d+|-?\\d+', question_text)\n","    numbers = []\n","    for n in numbers_raw:\n","        try:\n","            val = float(n)\n","            # Filter out unreasonably large numbers that might be noise\n","            if abs(val) < 1e6:\n","                numbers.append(val)\n","        except ValueError:\n","            continue\n","\n","    # Remove duplicates and sort\n","    numbers = sorted(list(set(numbers)))\n","\n","    # Replace your fraction extraction code (around line 250-270) with this:\n","\n","    # ===== STEP 2: Extract all fractions (KEEP ORIGINAL FORM) =====\n","    fractions_raw = re.findall(r'\\\\frac\\{(-?\\d+)\\}\\{(-?\\d+)\\}', question_text)\n","    fractions_obj = []\n","    fractions_original = []  # NEW: Keep original numerator/denominator\n","\n","    for num_str, den_str in fractions_raw:\n","        try:\n","            num, den = int(num_str), int(den_str)\n","            if den != 0:\n","                # Store simplified Fraction object\n","                f = Fraction(num, den)\n","                fractions_obj.append(f)\n","\n","                # Store original numerator/denominator (unsimplified)\n","                fractions_original.append((num, den))\n","        except (ValueError, ZeroDivisionError):\n","            continue\n","\n","    fractions_obj = sorted(list(set(fractions_obj)))\n","    # Keep original fractions paired with simplified ones\n","    # Create mapping: simplified -> original\n","    frac_to_original = {}\n","    for orig_num, orig_den in fractions_original:\n","        simplified = Fraction(orig_num, orig_den)\n","        if simplified not in frac_to_original:\n","            frac_to_original[simplified] = (orig_num, orig_den)\n","\n","    # ===== STEP 3: Build Feature List =====\n","    features = []\n","\n","    # Metadata\n","    features.append(f\"SA:{student_answer}\")\n","    features.append(f\"NUM_COUNT:{len(numbers)}\")\n","    features.append(f\"FRAC_COUNT:{len(fractions_obj)}\")\n","\n","    # Raw numbers\n","    for i, n in enumerate(numbers, 1):\n","        features.append(f\"N{i}:{n:.6g}\")\n","\n","    # ===== STEP 4: Fraction Features =====\n","    for i, f in enumerate(fractions_obj, 1):\n","        # Original fraction\n","        features.append(f\"F{i}:{f.numerator}/{f.denominator}\")\n","        features.append(f\"F{i}_DEC:{float(f):.6g}\")\n","\n","        # Numerator vs Denominator comparison\n","        features.append(f\"F{i}_NUM:{f.numerator}\")\n","        features.append(f\"F{i}_DEN:{f.denominator}\")\n","        if f.numerator > f.denominator:\n","            features.append(f\"F{i}_NUM_GT_DEN:TRUE\")\n","        elif f.numerator < f.denominator:\n","            features.append(f\"F{i}_NUM_LT_DEN:TRUE\")\n","        else:\n","            features.append(f\"F{i}_NUM_EQ_DEN:TRUE\")\n","\n","        # Complementary fraction (1 - f)\n","        comp = 1 - f\n","        features.append(f\"F{i}_COMP:{comp.numerator}/{comp.denominator}\")\n","        features.append(f\"F{i}_COMP_DEC:{float(comp):.6g}\")\n","\n","        # Reciprocal (1/f) if not zero\n","        if f.numerator != 0:\n","            recip =