xt/plain":["merges.txt: 0.00B [00:00, ?B/s]"]},"metadata":{},"output_type":"display_data"},{"data":{"application/vnd.jupyter.widget-view+json":{"model_id":"8a901909a69440c38933a4a57afa1537","version_major":2,"version_minor":0},"text/plain":["tokenizer.json: 0.00B [00:00, ?B/s]"]},"metadata":{},"output_type":"display_data"},{"name":"stdout","output_type":"stream","text":["\n","🧮 Creating mathematical context...\n","📦 Creating test dataset...\n","\n","🚀 Running inference...\n","\n","================================================================================\n","INFERENCE RESULTS\n","================================================================================\n","\n","Question: calculate \\(\\frac{1}{9} \\div 18\\). Simplify if necessary. \\( 2 \\)\n","\n","Student Explanation:  <MATH_CONTEXT> F1_NUM_LT_DEN:TRUE | ANSWER_HAS_FRACTION:FALSE </MATH_CONTEXT>  I think this because if you divide F1 by a whole number its the same as just taking F1 of N3. You get F1xN3_SwapDividend_UNSIM and that is F1xN3_SwapDividend_MIXED\n","Student Answer: \\( 2 \\)\n","\n","Correctness Prediction: Incorrect\n","\n","Top Category Prediction (Single-Label):\n","  ✓ False_Misconception: 0.9376\n","\n","Top 3 Misconception Predictions (Multi-Label):\n","  ✓ Mult: 0.9994\n","  ✗ SwapDividend: 0.0004\n","  ✗ Wrong_fraction: 0.0000\n","\n","Ground Truth:\n","  Correctness: Incorrect\n","  Categories: False_Misconception\n","  Misconceptions: ['Mult']\n","================================================================================\n"]}],"source":["# ============================================================================\n","# INFERENCE FUNCTION\n","# ============================================================================\n","\n","def run_dataloader_inference(model, data_loader, device, label_encoder_category,\n","                            label_encoder_misconception, df=None):\n","    \"\"\"Run inference on a single batch from the dataloader\"\"\"\n","    model.eval()\n","\n","    with torch.no_grad():\n","        for batch in data_loader:\n","            input_ids = batch['input_ids'].to(device)\n","            attention_mask = batch['attention_mask'].to(device)\n","\n","            # Forward pass\n","            correctness_logits, category_logits, misconception_logits = model(\n","                input_ids, attention_mask\n","            )\n","\n","            # --- Process Predictions ---\n","\n","            # Correctness (Binary Classification)\n","            correctness_pred = torch.argmax(correctness_logits, dim=-1).item()\n","\n","            # Category and Misconception (Multi-Label Classification)\n","            category_probs = torch.sigmoid(category_logits).float().cpu().numpy()[0]\n","            misconception_probs = torch.sigmoid(misconception_logits).float().cpu().numpy()[0]\n","\n","            category_preds = (category_probs > 0.5).astype(int)\n","            misconception_preds = (misconception_probs > 0.5).astype(int)\n","\n","            top_category_indices = np.argsort(category_probs)[-3:][::-1]\n","            top_misconception_indices = np.argsort(misconception_probs)[-3:][::-1]\n","\n","            # --- Print Results ---\n","            print(\"=\"*80)\n","            print(\"INFERENCE RESULTS\")\n","            print(\"=\"*80)\n","            print(f\"\\nQuestion: {batch['question_text'][0]}\")\n","            print(f\"\\nStudent Explanation: {batch['explanation_text'][0]}\")\n","            try:\n","                print(f\"Student Answer: {df.iloc[0]['MC_Answer']}\")\n","            except:\n","                print()\n","\n","            print(f\"\\nCorrectness Prediction: {'Correct' if correctness_pred == 1 else 'Incorrect'}\")\n","            print()\n","\n","            print(\"Top 3 Category Predictions:\")\n","            for idx in top_category_indices:\n","                category_name = label_encoder_category.inverse_transform([idx])[0]\n","                prob = category_probs[idx]\n","                predicted = \"✓\" if category_preds[idx] == 1 else \"✗\"\n","                print(f\"  {predicted} {category_name}: {prob:.4f}\")\n","            print()\n","\n","            print(\"Top 3 Misconception Predictions:\")\n","            for idx in top_misconception_indices:\n","                misconception_name = label_encoder_misconception.inverse_transform([idx])[0]\n","                prob = misconception_probs[idx]\n","                predicted = \"✓\" if misconception_preds[idx] == 1 else \"✗\"\n","                print(f\"  {predicted} {misconception_name}: {prob:.4f}\")\n","            print()\n","\n","            print(\"Ground Truth:\")\n","            if df is not None:\n","                print(f\"  Correctness: {'Correct' if df.iloc[0]['Correctness'] == 1 else 'Incorrect'}\")\n","                print(f\"  Categories: {df.iloc[0]['Category']}\")\n","                print(f\"  Misconceptions: {df.iloc[0]['Misconception']}\")\n","            print(\"=\"*80)\n","\n","            return  # Only process the single item\n","\n","def run_dataloader_inference(model, data_loader, device, label_encoder_category,\n","                            label_encoder_misconception, df=None):\n","    \"\"\"Run inference on a single batch from the dataloader\"\"\"\n","    model.eval()\n","\n","    with torch.no_grad():\n","        for batch in data_loader:\n","            input_ids = batch['input_ids'].to(device)\n","            attention_mask = batch['attention_mask'].to(device)\n","\n","            # Forward pass\n","            correctness_logits, category_logits, misconception_logits = model(\n","                input_ids, attention_mask\n","            )\n","\n","            # --- Process Predictions ---\n","\n","            # Correctness (Binary Classification - Argmax on 2 logits)\n","            correctness_pred = torch.argmax(correctness_logits, dim=-1).item()\n","\n","            # ------------------------------------------------------------------\n","            # ✅ CHANGE 1: Category is now Single-Label (Softmax + Argmax)\n","            # ------------------------------------------------------------------\n","\n","            # Category (Single-Label Multi-Class)\n","            # Apply Softmax to get probabilities (sum to 1)\n","            category_probs = torch.softmax(category_logits, dim=-1).float().cpu().numpy()[0]\n","\n","            # The final prediction is the class with the highest probability (argmax)\n","            category_pred_idx = np.argmax(category_probs)\n","\n","            # Create a one-hot array for prediction (for simplified printing logic)\n","            category_preds_onehot = np.zeros_like(category_probs, dtype=int)\n","            category_preds_onehot[category_pred_idx] = 1\n","\n","            # ------------------------------------------------------------------\n","            # Misconception (STILL Multi-Label - Sigmoid + Threshold)\n","            # ------------------------------------------------------------------\n","\n","            misconception_probs = torch.sigmoid(misconception_logits).float().cpu().numpy()[0]\n","            misconception_preds = (misconception_probs > 0.5).astype(int)\n","\n","            # --- Prepare Indices for Printing ---\n","\n","            # For Category, we only care about the single highest prediction\n","            top_category_indices = [category_pred_idx] # Only top prediction matters\n","\n","            # For Misconception, show top 3 based on probability\n","            top_misconception_indices = np.argsort(misconception_probs)[-3:][::-1]\n","\n","            # --- Print Results ---\n","            print(\"=\"*80)\n","            print(\"INFERENCE RESULTS\")\n","            print(\"=\"*80)\n","            print(f\"\\nQuestion: {batch['question_text'][0]}\")\n","            print(f\"\\nStudent Explanation: {batch['explanation_text'][0]}\")\n","            try:\n","                print(f\"Student Answer: {df.iloc[0]['MC_Answer']}\")\n","            except:\n","                print()\n","\n","            print(f\"\\nCorrectness Prediction: {'Correct' if correctness_pred == 1 else 'Incorrect'}\")\n","            print()\n","\n","            # ------------------------------------------------------------------\n","            # ✅ CHANGE 2: Print only the single predicted category\n","            # ------------------------------------------------------------------\n","            print(\"Top Category Prediction (Single-Label):\")\n","            category_name = label_encoder_category.inverse_transform([category_pred_idx])[0]\n","            prob = category_probs[category_pred_idx]\n","            print(f\"  ✓ {category_name}: {prob:.4f}\")\n","            print()\n","\n","            # --- Misconception Print remains the same ---\n","            print(\"Top 3 Misconception Predictions (Multi-Label):\")\n","            for idx in top_misconception_indices:\n","                misconception_name = label_encoder_misconception.inverse_transform([idx])[0]\n","                prob = misconception_probs[idx]\n","                predicted = \"✓\" if misconception_preds[idx] == 1 else \"✗\"\n","                print(f\"  {predicted} {misconception_name}: {prob:.4f}\")\n","            print()\n","\n","            print(\"Ground Truth:\")\n","            if df is not None:\n","                print(f\"  Correctness: {'Correct' if df.iloc[0]['Correctness'] == 1 else 'Incorrect'}\")\n","                print(f\"  Categories: {df.iloc[0]['Category']}\")\n","                print(f\"  Misconceptions: {df.iloc[0]['Misconception']}\")\n","            print(\"=\"*80)\n","\n","            return\n","# ============================================================================\n","# MAIN INFERENCE SCRIPT\n","# ============================================================================\n","\n","def run_inference_on_sample(test_sample, label_encoder_category, label_encoder_misconception,\n","                           augmenter, create_generic_math_context,\n","                           MultiTaskDatasetTextAugmentedB, MultiTaskQwen,\n","                           checkpoint_dir):\n","    \"\"\"\n","    Run inference on a single test sample.\n","\n","    Args:\n","        test_sample: Dictionary with keys: QuestionText, StudentExplanation, Category,\n","                    Misconception, MC_Answer, Correctness\n","        label_encoder_category: Fitted LabelEncoder for categories\n","        label_encoder_misconception: Fitted LabelEncoder for misconceptions\n","        augmenter: Text augmentation object\n","        create_generic_math_context: Function to create mathematical context\n","        MultiTaskDatasetTextAugmentedB: Dataset class\n","        MultiTaskQwen: Model class\n","        checkpoint_dir: Directory containing the checkpoint file\n","    \"\"\"\n","\n","    # Configuration\n","    MODEL_NAME = 'Qwen/Qwen2-7B-Instruct'\n","    CHECKPOINT_FNAME = 'stage2_explanation_model_dec5_MISC_ONLY_SUB.pt' #'large_map_qwen_model_other_nov20.pt'#'large_map_qwen_model.pt'\n","\n","    # Define checkpoint path\n","    checkpoint_path = os.path.join(checkpoint_dir, CHECKPOINT_FNAME)\n","\n","    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n","    print(f\"Using device: {device}\")\n","\n","    # Load checkpoint\n","    print(f\"\\n🔄 Loading checkpoint from: {checkpoint_path}\")\n","    if not os.path.exists(checkpoint_path):\n","        raise FileNotFoundError(f\"Checkpoint not found at {checkpoint_path}\")\n","\n","    checkpoint = torch.load(checkpoint_path, map_location=device, weights_only=False)\n","\n","    # Get model configuration\n","    num_categories = len(label_encoder_category.classes_)\n","    num_misc_classes = len(label_encoder_misconception.classes_)\n","\n","    print(f\"📊 Model Configuration:\")\n","    print(f\"  - Categories: {num_categories}\")\n","    print(f\"  - Misconceptions: {num_misc_classes}\")\n","\n","    # Define BitsAndBytes Config\n","    bnb_config = BitsAndBytesConfig(\n","        load_in_4bit=True,\n","        bnb_4bit_quant_type=\"nf4\",\n","        bnb_4bit_compute_dtype=torch.bfloat16,\n","        bnb_4bit_use_double_quant=True\n","    )\n","\n","    # Initialize model architecture\n","    print(f\"\\n🏗️ Initializing model architecture...\")\n","    model = MultiTaskQwen(\n","        MODEL_NAME,\n","        num_categories,\n","        num_misc_classes,\n","        bnb_config=bnb_config\n","    )\n","\n","    # Apply LoRA configuration (MUST match training)\n","    print(f\"🔧 Preparing model for LoRA...\")\n","    model.qwen = prepare_model_for_kbit_training(model.qwen)\n","\n","    lora_config = LoraConfig(\n","        r=64,\n","        lora_alpha=64,\n","        target_modules=[\"q_proj\", \"v_proj\", \"k_proj\", \"o_proj\"],\n","        lora_dropout=0.05,\n","        bias=\"none\",\n","        task_type=\"FEATURE_EXTRACTION\"\n","    )\n","\n","    model.qwen = get_peft_model(model.qwen, lora_config)\n","    print(\"✅ LoRA adapters injected into the model's transformer backbone.\")\n","\n","    # 🔥 CRITICAL: Load the trained weights from checkpoint\n","    print(f\"\\n⚡ Loading trained weights from checkpoint...\")\n","    try:\n","        model.load_state_dict(checkpoint['model_state_dict'], strict=False)\n","        print(\"✅ Model weights loaded successfully!\")\n","\n","        # Print checkpoint info\n","        if 'epoch' in checkpoint:\n","            print(f\"📈 Checkpoint Info:\")\n","            print(f\"  - Epoch: {checkpoint['epoch']}\")\n","            print(f\"  - Validation Loss: {checkpoint.get('val_loss', 'N/A'):.4f}\")\n","            #print(f\"  - Validation F1: {checkpoint.get('val_f1', 'N/A'):.4f}\")\n","    except Exception as e:\n","        print(f\"❌ Error loading weights: {e}\")\n","        raise\n","\n","    # Move to device and set to eval mode\n","    model.to(device)\n","    model.eval()\n","    print(f\"✅ Model moved to {device} and set to eval