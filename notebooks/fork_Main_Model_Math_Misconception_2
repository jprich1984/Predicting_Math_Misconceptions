amples for augment_inversion_misconception\n","Generated 8616 examples for augment_duplication_misconception\n","Generated 962 examples for augment_wrong_operation_misconception\n","Generated 1560 examples for augment_firstterm_misconception\n","Generated 1125 examples for augment_base_rate\n","Generated 4500 examples for augment_division\n","Generated 1362 examples for augment_scale_misconception\n","Generated 1240 examples for augment_certainty_misconception\n","Generated 1330 examples for augment_unknowable_misconception\n","Generated 1044 examples for augment_definition\n","Generated 646 examples for augment_interior_misconception\n","Generated 1520 examples for augment_wnb\n","Generated 936 examples for augment_tacking\n","Generated 1000 examples for augment_positive\n","Generated 1200 examples for augment_whole_number_bias\n","Generated 720 examples for augment_ignores_zeroes\n","Generated 1320 examples for augment_shorter_is_bigger\n","Generated 2000 examples for augment_not_variable\n","Generated 2400 examples for augment_adding_terms\n","Generated 1440 examples for augment_inverse_operation2\n","Generated 972 examples for augment_denominator_only_change\n","Generated 338 examples for augment_adding_across\n","Generated 1013 examples for augment_incorrect_equivalent_fraction_addition\n","Generated 896 examples for augment_additive_equivalent_fraction\n","Generated 620 examples for augment_wrongterm_misconception\n","Generated 100 examples for augment_positive_and_adding_across\n","Generated 285 examples for augment_multiply_fractions_correct\n","Generated 95 examples for augment_divide_fractions_correct\n","Generated 100 examples for augment_add_fractions_correct\n","Generated 538 examples for augment_fraction_same_color_problems\n","Generated 279 examples for augment_wrong_fraction2\n","Generated 800 examples for augment_subtraction2\n","Generated 475 examples for augment_inverse_operation3\n","Generated 1248 examples for augment_adding_across2\n","Generated 700 examples for augment_interior2\n","Generated 951 examples for augment_denominator_only_change2\n","Generated 8140 examples for augment_wrongterm_misconception2\n","Generated 1000 examples for augment_division2\n","Generated 780 examples for augment_scale_certainty_misconception\n","Generated 900 examples for augment_multiplying_by_4_two\n","Generated 800 examples for augment_unknowable_misconception2\n","Generated 1292 examples for augment_inversion_misconception2\n","Generated 1200 examples for augment_whole_number_bias2\n","Generated 720 examples for augment_ignores_zeroes2\n","Generated 1100 examples for augment_shorter_is_bigger2\n","Generated 1307 examples for augment_longer_is_bigger_two_numbers\n","Generated 900 examples for augment_whole_number_bias_three\n","Generated 900 examples for augment_whole_number_bias_three_greatest\n","Generated 900 examples for augment_decimal_comparison_correct\n","Generated 1973 examples for augment_longer_is_bigger_smallest\n","Generated 554 examples for augment_low_probability_misconception\n","Length of All Data 23489\n","Original samples: 82216\n","here\n","Deduplicated samples 1 time: 10993\n","\n","Deduplicated samples for Stage 2: 33467\n"]}],"source":["def create_structural_explanation_key(explanation_text):\n","    \"\"\"\n","    Normalizes the student explanation by replacing numbers with a [NUM] token\n","    to generate a unique structural key.\n","\n","    Args:\n","        explanation_text (str): The raw student explanation.\n","\n","    Returns:\n","        str: The canonical, value-independent explanation template.\n","    \"\"\"\n","    # 1. Replace fractions (like 1/3, 3/8, 4/11) with a single token\n","    # Pattern: Digit(s), followed by /, followed by Digit(s)\n","    normalized_text = re.sub(r'\\d+\\s*/\\s*\\d+', '[FRAC]', explanation_text)\n","\n","    # 2. Replace all remaining standalone numbers (integers and decimals)\n","    # This should catch 1, 2, 3, 5, 8, etc.\n","    # Pattern: Optional sign/decimal point, followed by one or more digits\n","    # Use word boundaries (\\b) to avoid replacing numbers inside words (e.g., '1' in 'C1')\n","    normalized_text = re.sub(r'(\\b\\d+(\\.\\d*)?\\b)|(\\b\\.\\d+\\b)', '[NUM]', normalized_text)\n","\n","    # 3. Clean up the text: lowercase, remove extra spaces, and strip punctuation\n","    normalized_text = normalized_text.lower()\n","    normalized_text = re.sub(r'\\s+', ' ', normalized_text).strip()\n","\n","    return normalized_text\n","\n","\n","augmented_data_set_all=augment_functions.generate_all_augmented_data(change_cat_prob=0.00)\n","augmented_data_set_all['Structural_Key'] = augmented_data_set_all['StudentExplanation'].apply(create_structural_explanation_key)\n","\n","do_deduplicate=True\n","if do_deduplicate:\n","  # 2. Deduplicate\n","  print(f\"Original samples: {len(augmented_data_set_all)}\")\n","  states=[i for i in range(100)]\n","  augmented_data_set=augmented_data_set_all.groupby(['Structural_Key']).first().reset_index()\n","  print('here')\n","  print(f\"Deduplicated samples 1 time: {len(augmented_data_set)}\")\n","  print()\n","  for state in range(41,43):\n","    augmented_data_set_all=augmented_data_set_all.sample(frac=1,random_state=states[state])\n","  # Group by the key and the Misconception (in case the same template applies to different problems)\n","    augmented_data_set = pd.concat([augmented_data_set, augmented_data_set_all.groupby(['Structural_Key']).first().reset_index()])\n","  for state in range(11,15):\n","    augmented_data_set_all=augmented_data_set_all.sample(frac=1,random_state=states[state])\n","    is_irrelevant = augmented_data_set_all['Misconception'].apply(\n","    lambda x: 'Irrelevant' in x\n",")\n","\n","# 2. Use the boolean Series to filter the DataFrame\n","    irrelevant_set = augmented_data_set_all[is_irrelevant].copy()\n","    augmented_data_set = pd.concat([augmented_data_set, irrelevant_set.groupby(['Structural_Key']).first().reset_index()])\n","\n","augmen